{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "allowJs": true,
    "lib": [
      "es2019"
    ],
    "module": "commonjs",
    "target": "es2019",
    "types": [
      "node"
    ],
    "noEmitOnError": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "declaration": true
  },
  "include": [
    "./src/**/*"
  ]
}
